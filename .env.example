# Server
HOST=0.0.0.0
PORT=8080
FRONTEND_DIST_DIR=frontend/dist

# myClawTeam platform email proxy. Keep the token server-side only.
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=app_example_token

# Send endpoint rate limit defaults
RATE_LIMIT_REQUESTS_PER_WINDOW=5
RATE_LIMIT_WINDOW_SECONDS=60
